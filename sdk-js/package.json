{
  "name": "@botcierge/sdk",
  "version": "0.1.1",
  "description": "SDK for Botcierge Intent Classification",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run",
    "lint": "tsc"
  },
  "keywords": [
    "botcierge",
    "intent",
    "classifier",
    "sdk"
  ],
  "author": "horribleprogram",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
